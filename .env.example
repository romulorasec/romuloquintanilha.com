# Copy this file to .env.local and fill in the values
# .env.local is gitignored — never commit it

# ──────────────────────────────────────────
# Required
# ──────────────────────────────────────────

# Public URL of the site (no trailing slash)
# Production: https://romuloquintanilha.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Default locale for the site
NEXT_PUBLIC_DEFAULT_LOCALE=en-US

# ──────────────────────────────────────────
# Contact form — security
# ──────────────────────────────────────────

# Allowed production origin for the /api/contact route.
# ⚠ Server-only — NEVER add NEXT_PUBLIC_ prefix.
# Production: https://romuloquintanilha.com (no trailing slash, no www)
ALLOWED_ORIGIN=https://romuloquintanilha.com

# ──────────────────────────────────────────
# Contact form — Resend (https://resend.com)
# ──────────────────────────────────────────

# ⚠ Server-only — NEVER add NEXT_PUBLIC_ prefix.
# Create a key with "Sending access" only (not Full access).
RESEND_API_KEY=

# Email address that receives quote requests (your personal inbox).
# ⚠ Server-only — NEVER add NEXT_PUBLIC_ prefix.
QUOTE_TO_EMAIL=

# Verified sender address in Resend (must match your verified domain).
# Example: noreply@romuloquintanilha.com
# ⚠ Server-only — NEVER add NEXT_PUBLIC_ prefix.
QUOTE_FROM_EMAIL=

# ──────────────────────────────────────────
# Contact form — Cloudflare Turnstile (https://dash.cloudflare.com)
# ──────────────────────────────────────────

# Public site key — safe to expose in the browser.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ⚠ Server-only — NEVER add NEXT_PUBLIC_ prefix.
# Used to verify Turnstile tokens server-side via siteverify API.
TURNSTILE_SECRET_KEY=

# ──────────────────────────────────────────
# Analytics (optional)
# ──────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# ──────────────────────────────────────────
# Maps (optional — if map embed is added)
# ──────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
