# Copy this file to .env.local and fill in the values
# .env.local is gitignored — never commit it

# ──────────────────────────────────────────
# Required
# ──────────────────────────────────────────

# Public URL of the site (no trailing slash)
# Production: https://romuloquintanilha.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Default locale for the site
NEXT_PUBLIC_DEFAULT_LOCALE=en-US

# ──────────────────────────────────────────
# Contact form — Resend (https://resend.com)
# Set when the contact form is implemented
# ──────────────────────────────────────────
RESEND_API_KEY=

# ──────────────────────────────────────────
# Analytics (optional)
# ──────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# ──────────────────────────────────────────
# Maps (optional — if map embed is added)
# ──────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
